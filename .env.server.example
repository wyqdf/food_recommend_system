SEARCH_ES_AUTO_CREATE_INDEX=true

JWT_SECRET=CHANGE_ME_JWT_SECRET

ALIYUN_OSS_ENABLED=true
ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
