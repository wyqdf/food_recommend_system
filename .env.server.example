MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=food_recommend
MYSQL_USER=food_app
MYSQL_PASSWORD=CHANGE_ME_APP_DB_PASSWORD
MYSQL_PORT=3306

BACKEND_PORT=8081
FRONTEND_PORT=3000
SEARCH_ENGINE=auto
SPRING_ELASTICSEARCH_URIS=http://elasticsearch:9200
SEARCH_ES_INDEX_ALIAS=recipes_search
SEARCH_ES_INDEX_NAME=recipes_search_v2
